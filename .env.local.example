# ─────────────────────────────────────────────
# AI News Blog System — Environment Variables
# Copy this file to .env and fill in values
# ─────────────────────────────────────────────

# ── Database ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ai_blog_db
DB_USER=root
DB_PASSWORD=""

# ── Authentication ────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret_string_min_64_chars
JWT_EXPIRES_IN=7d

# ── Google Gemini AI ──────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash

# ── Server ────────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173

# ── Frontend (Vite) ───────────────────────────
VITE_API_BASE_URL=http://localhost:5000/api
VITE_APP_NAME=AI News Blog
